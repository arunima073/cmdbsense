(function execute(inputs, outputs) {


    // Load CI A
    var ciA = new GlideRecord('cmdb_ci');

    if (!ciA.get(inputs.ci_a)) {

        gs.error("CI A not found: " + inputs.ci_a);
        return;

    }


    // Reload CI A using actual class
    var ciATable = ciA.getValue('sys_class_name');

    gs.info(
        "CI A Class = " + ciATable
    );


    if (ciATable) {

        var ciAActual = new GlideRecord(ciATable);

        if (ciAActual.get(inputs.ci_a)) {
            ciA = ciAActual;
        }

    }





    // Load CI B
    var ciB = new GlideRecord('cmdb_ci');

    if (!ciB.get(inputs.ci_b)) {

        gs.error("CI B not found: " + inputs.ci_b);
        return;

    }


    // Reload CI B using actual class
    var ciBTable = ciB.getValue('sys_class_name');

    gs.info(
        "CI B Class = " + ciBTable
    );


    if (ciBTable) {

        var ciBActual = new GlideRecord(ciBTable);

        if (ciBActual.get(inputs.ci_b)) {
            ciB = ciBActual;
        }

    }






    gs.info("CI A = " + ciA.getDisplayValue());
    gs.info("CI B = " + ciB.getDisplayValue());

    gs.info(
        "CI A sys_class_name = " +
        ciA.getValue('sys_class_name')
    );

    gs.info(
        "CI B sys_class_name = " +
        ciB.getValue('sys_class_name')
    );






    // Call Winner Picker

    var picker =
        new x_angda_avante_c_0.AvnCmdbWinnerPicker();



    var winner =
        picker.pick(
            ciA,
            ciB
        );





    gs.info(
        "Winner = " +
        winner.getDisplayValue()
    );

    gs.info(
        "Winner sys_id = " +
        winner.getUniqueValue()
    );






    outputs.winner_ci =
        winner.getUniqueValue();





    // Determine loser

    var loser;


    if (
        winner.getUniqueValue() ==
        ciA.getUniqueValue()
    ) {

        loser = ciB;

    }
    else {

        loser = ciA;

    }




    outputs.loser_ci =
        loser.getUniqueValue();



    gs.info(
        "Loser = " +
        loser.getDisplayValue()
    );



})(inputs, outputs);
